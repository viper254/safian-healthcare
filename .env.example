# =============================================================================
# SAFIAN HEALTHCARE & MEDICAL SUPPLIES - Environment Variables
# =============================================================================
# 
# SETUP INSTRUCTIONS:
# 1. Copy this file to `.env.local` (in the same directory)
# 2. Go to https://supabase.com and create a new project
# 3. In Supabase dashboard → Project Settings → API, copy:
#    - Project URL → NEXT_PUBLIC_SUPABASE_URL
#    - anon public key → NEXT_PUBLIC_SUPABASE_ANON_KEY
# 4. Fill in the values below
# 5. Restart your dev server: npm run dev
#
# NOTE: When these are NOT set, the app runs in "demo mode" with mock data
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE (REQUIRED)
# -----------------------------------------------------------------------------
# Get these from: Supabase Dashboard → Project Settings → API

# Your Supabase project URL (e.g., https://xxxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Your Supabase anon/public key (long string starting with "eyJ...")
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# SUPABASE SERVICE ROLE (OPTIONAL)
# -----------------------------------------------------------------------------
# Only needed for server-side operations with elevated privileges
# Get from: Supabase Dashboard → Project Settings → API → service_role key
# WARNING: Keep this secret! Never expose to browser/client code

SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# SITE CONFIGURATION (OPTIONAL)
# -----------------------------------------------------------------------------

# Your production site URL (used for SEO, OG images, canonical links)
# Development: http://localhost:3000
# Production: https://safianhealthcare.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# CONTACT INFORMATION (OPTIONAL - Overrides defaults)
# -----------------------------------------------------------------------------
# These override the values in src/lib/constants.ts

# NEXT_PUBLIC_CONTACT_PHONE=0756 597 813
# NEXT_PUBLIC_CONTACT_WHATSAPP=254756597813
# NEXT_PUBLIC_CONTACT_EMAIL=info@safianhealthcare.com

# -----------------------------------------------------------------------------
# ANALYTICS (OPTIONAL)
# -----------------------------------------------------------------------------

# Google Analytics Measurement ID
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Vercel Analytics (automatically enabled on Vercel)
# No configuration needed

# -----------------------------------------------------------------------------
# PAYMENT GATEWAYS (OPTIONAL - For future use)
# -----------------------------------------------------------------------------

# M-Pesa (Safaricom - Kenya)
# NEXT_PUBLIC_MPESA_CONSUMER_KEY=
# NEXT_PUBLIC_MPESA_CONSUMER_SECRET=
# NEXT_PUBLIC_MPESA_SHORTCODE=
# NEXT_PUBLIC_MPESA_PASSKEY=

# Stripe
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
# STRIPE_SECRET_KEY=sk_test_xxxxx

# -----------------------------------------------------------------------------
# EMAIL SERVICE (OPTIONAL - For future use)
# -----------------------------------------------------------------------------

# SendGrid
# SENDGRID_API_KEY=SG.xxxxx
# SENDGRID_FROM_EMAIL=noreply@safianhealthcare.com

# Resend
# RESEND_API_KEY=re_xxxxx
# RESEND_FROM_EMAIL=noreply@safianhealthcare.com

# -----------------------------------------------------------------------------
# NOTES
# -----------------------------------------------------------------------------
# 1. Never commit .env.local to version control (it's in .gitignore)
# 2. Only NEXT_PUBLIC_* variables are exposed to the browser
# 3. All other variables are server-side only
# 4. Restart dev server after changing environment variables
# 5. For production (Vercel), add these in: Settings → Environment Variables
# =============================================================================
