th# =============================================================================
# SAFIAN HEALTHCARE & MEDICAL SUPPLIES - Environment Variables Template
# =============================================================================
# 
# SETUP INSTRUCTIONS:
# 1. Copy this file to `.env` (in the same directory)
# 2. Go to https://supabase.com and create a new project
# 3. In Supabase dashboard → Project Settings → API, copy:
#    - Project URL → NEXT_PUBLIC_SUPABASE_URL
#    - anon public key → NEXT_PUBLIC_SUPABASE_ANON_KEY
# 4. Fill in the values below
# 5. Restart your dev server: npm run dev
#
# NOTE: This same .env file works for both local and production
# Just update NEXT_PUBLIC_SITE_URL when deploying
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE (REQUIRED)
# -----------------------------------------------------------------------------
# Get these from: Supabase Dashboard → Project Settings → API

# Your Supabase project URL (e.g., https://xxxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Your Supabase anon/public key (long string starting with "eyJ...")
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# -----------------------------------------------------------------------------
# SITE CONFIGURATION
# -----------------------------------------------------------------------------
# Current: https://safian-healthcare.vercel.app
# When you get a custom domain, update this to: https://safianhealthcare.com
NEXT_PUBLIC_SITE_URL=https://safian-healthcare.vercel.app

# -----------------------------------------------------------------------------
# CONTACT INFORMATION (OPTIONAL - Overrides defaults)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CONTACT_PHONE=0756 597 813
NEXT_PUBLIC_CONTACT_WHATSAPP=254756597813
NEXT_PUBLIC_CONTACT_EMAIL=info@safianhealthcare.com

# -----------------------------------------------------------------------------
# ANALYTICS (OPTIONAL)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================
# For production (Vercel/Netlify):
# 1. Add these same variables in your hosting platform's environment settings
# 2. Change NEXT_PUBLIC_SITE_URL to your production domain
#    - Vercel: https://your-app.vercel.app
#    - Netlify: https://your-app.netlify.app
#    - Custom domain: https://safianhealthcare.com
# 3. Deploy!
#
# Quick Deploy Commands:
# - Vercel: vercel --prod
# - Netlify: netlify deploy --prod
#
# See QUICK_START_GOOGLE.md for complete deployment guide
# =============================================================================
