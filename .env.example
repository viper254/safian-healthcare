# -----------------------------------------------------------------------------
# Safian Healthcare & Supplies — environment variables
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in real values. When these are NOT
# set the app runs in "demo" mode using in-memory mock data (useful for preview
# deployments).

# Public Supabase URL (found in Supabase dashboard → Project settings → API)
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional — used only by server-side routes that need elevated privileges
# (e.g. inserting analytics for anonymous checkouts). Do NOT expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Optional — public site URL used for SEO canonical links / OG images
NEXT_PUBLIC_SITE_URL=https://safian.example.com
